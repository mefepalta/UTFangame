dialogue = [
    {time: 1, text: "..."},
    {time: 3, text: "Papyrus... Alphys..."},
    {time: 6, text: ""},
    {time: 11, text: "So that's how this ends."},
	{time: 14, text: "The great and ancient power of determination..."},
	{time: 18, text: "Defeated by a single human."},
	{time: 21, text: "This is just..."},
	{time: 24, text: "So unfair!"},
	{time: 27, text: "I've worked my whole life to get to this point!"},
	{time: 31, text: "All that couldn't have been for nothing, right?"},
	{time: 35, text: "Why... Why did my determination choose to fail me?"},
	{time: 39, text: "Was I... too weak to wield that?"},
	{time: 43, text: "I'm supposed to be Sans The Great!"},
	{time: 47, text: "invincible... unbeatable to all who dare to cross me!"},
	{time: 51, text: "You weren't supposed to..."},
	{time: 54, text: "...to... win..."},
	{time: 57, text: "..."},
	{time: 60, text: "..."},
	{time: 63, text: "N-No. No."},
	{time: 66, text: "This... This isn't where my story ends..!"},
	{time: 70, text: "I know..."},
	{time: 73, text: "That great power we call determination may have left my soul..."},
	{time: 78, text: "Perhaps for good this time."},
	{time: 81, text: "But I still have one thing you will never have... and that's…"},
	{time: 86, text: "a soul!"},
	{time: 89, text: "Or, rather, an artificial soul."},
	{time: 93, text: "So... I'm the last hope for their survival, huh?"},
	{time: 96, text: "The last man standing?"},
	{time: 99, text: "Heh..."},
	{time: 101, text: "I can live with that."},
	{time: 104, text: "Much better."},
	{time: 109, text: "Within my hands hold the power of destruction and creation."},
	{time: 1, text: "And I swear to strike you down, once and for all!"},
	{time: 1, text: "I will stop at nothing to ensure you pay the price of crossing me!"},
	{time: 1, text: "No, not just me, you've destroyed everyone's hopes and dreams."},
	{time: 1, text: "And for what? Power? Fame? Well congratulations, because now I’m here."},
	{time: 1, text: "A guard never flees from his foe!"},
	{time: 1, text: "And you are no exception."},
	{time: 1, text: "Let's prove who's the stronger MONSTER here!"},
	{time: 1, text: "Mweh heh heh!"}
];

