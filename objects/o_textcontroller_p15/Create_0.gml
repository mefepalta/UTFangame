dialogue = [
    {time: 5, text: "*huff* *puff*"},//
    {time: 7, text: "..."},//
    {time: 9, text: "Heh..."}, //theme//
    {time: 12, text: "Heheheh..."},//
	{time: 14, text: "Man."},//
	{time: 16, text: "I can't remember the last time someone's landed a decisive blow on me."},//
	{time: 20, text: "Well, perhaps ''decisive'' isn't right..."},//
	{time: 23, text: "You've yet to knock me off my feet, after all."},//
	{time: 27, text: "Come on..."},//
	{time: 29, text: "Where's that EXPLOSIVE power of yours?!"},
	{time: 32, text: "You can't POSSIBLY be the same person I saw take down the guard."},
	{time: 36, text: "And that fight against Alphys?!"},
	{time: 39, text: "Don't tell me it was just a FLUKE!"},
	{time: 42, text: "..."},
	{time: 44, text: "Heh..."},
	{time: 46, text: "But you know..."},
	{time: 48, text: "The thought of you having made it THIS far..."},
	{time: 51, text: "...while STILL holding back a large majority of your strength?"},
	{time: 55, text: "Man..."},
	{time: 57, text: "I'VE NEVER BEEN MORE EXCITED!"},
	{time: 60, text: "The ground convulses beneath you, throwing you off balance."},//screen dark
	{time: 64, text: "Light erupts from Sans' soul, flooding every corner of the room..."},
	{time: 68, text: "A searing blaze tears through the darkness, melting the walls like wax."},
	{time: 72, text: "The air thrums with a triumphant force you're all too familiar with..."},
	{time: 76, text: "Power incarnate."},
	{time: 78, text: "You watch as it slowly bares its teeth at you."},
	{time: 81, text: ""}
];

