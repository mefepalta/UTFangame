dialogue = [
    {time: 1, text: "Long ago, in a world far beneath the Earth..."},
    {time: 5, text: "Lived the Monster race of legends, in peace for many years."},
    {time: 9, text: "Until one day..."},
    {time: 12, text: "A human had fallen from the surface world."},
	{time: 16, text: "And caused great destruction among the Monster race."},
	{time: 20, text: "And wouldn't rest until they were all ash."},
	{time: 24, text: "And one monster, Papyrus, had grown sick of watching this rampage unfold."},
	{time: 29, text: "And had to do something to stop this."},
	{time: 33, text: "The human started to tear their way through Snowdin village."},
	{time: 37, text: "Papyrus couldn't take this anymore."},
	{time: 41, text: "He couldn't stand to see another monster's dust another time."},
	{time: 45, text: "So he approached Sans, telling him the human was already in Waterfall."},
	{time: 49, text: "Sans ran off angrily, annoyed that his brother withheld such news."},
	{time: 53, text: "And so Papyrus stayed, hoping to overpower the human once and for all."},
	{time: 57, text: "After a long, drawn out battle, the human remained victorious."},
	{time: 61, text: "Sans, being unfruitful in his efforts, returned to Snowdin."},
	{time: 65, text: "Wondering where that human could have gone."},
	{time: 69, text: "And once he returned..."},
	{time: 73, text: "Alas, all that laid before him, was the dust of his own brother."},
	{time: 78, text: "And right then and there, he knew that the only way to avenge the deaths of his friends..."},
	{time: 84, text: "Was to make the human suffer for everything they've done to hurt him."},
	{time: 88, text: "His pride, his people, and most of all, his brother."},
	{time: 92, text: "After all, he is..."},
	{time: 96, text: "The Endless Knight."},
];

current_line = -1;          // no line yet
start_time = current_time;  // starting point
line_start_time = 0;        // when current line started
char_speed = 0.05;          // seconds per letter
